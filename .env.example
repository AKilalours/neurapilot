# NeuraPilot — Environment Configuration
# Copy to .env and fill in your values

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama          # ollama | openai

# ── Ollama (local, private) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── OpenAI (cloud) ────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=6
CANDIDATE_K=16
CHUNK_SIZE=900
CHUNK_OVERLAP=180
MMR_LAMBDA=0.6               # MMR diversity lambda (0=diversity, 1=relevance)

# ── Grounding & Safety ────────────────────────────────────────────────────────
STRICT_GROUNDING=true
HALLUCINATION_GUARD=true     # enable hallucination-detection node

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=.data
UPLOAD_DIR=.data/uploads
DB_PATH=.data/neurapilot.db
CHROMA_DIR=.chroma
BASE_COLLECTION=neurapilot

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_ENABLED=true            # compute RAGAS-style metrics per interaction
